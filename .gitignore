*.swo

# Data — never commit large geospatial assets
data/raw/
data/cogs/
data/tmp/
*.tif
*.tiff
*.img
*.hgt
*.mbtiles
*.pmtiles

# Logs
*.log
logs/

# Frontend build artifacts. The app is pure TS/TSX; any .js under src/ is a
# stray `tsc` emit (Vite resolves .js before .tsx, so committed emits would
# shadow the real sources). tsconfig has noEmit:true to prevent this — these
# patterns are a backstop.
frontend/dist/
frontend/src/**/*.js
frontend/src/**/*.js.map
*.tsbuildinfo
