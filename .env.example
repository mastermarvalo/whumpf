# -----------------------------------------------------------------------------
# Whumpf — environment template
#
# Copy to .env and fill in real values.  Never commit .env.
#
# Prod setup
# ----------
# Set ALL values before running `make up` for the first time. The Postgres
# and MinIO volumes initialize from these on first start — changing them
# afterwards requires either nuking volumes or manual intervention inside
# the containers (ALTER ROLE in psql, mc admin user in MinIO).
#
# Generate secrets:
#   JWT_SECRET          →  openssl rand -hex 32
#   POSTGRES_PASSWORD   →  openssl rand -base64 24
#   MINIO_ROOT_PASSWORD →  openssl rand -base64 18   (must be ≥ 8 chars)
# -----------------------------------------------------------------------------

# --- PostGIS ----------------------------------------------------------------
# POSTGRES_USER / POSTGRES_DB — pick a name (e.g. whumpf). Set once, never
# change without nuking the volume or running ALTER ROLE / ALTER DATABASE.
POSTGRES_DB=whumpf
POSTGRES_USER=whumpf
POSTGRES_PASSWORD=change-me                    # openssl rand -base64 24

# --- MinIO ------------------------------------------------------------------
# MINIO_ROOT_USER: min 3 chars. MINIO_ROOT_PASSWORD: min 8 chars.
# Same first-run rule applies — set before `make up`, or nuke the volume to
# change.
MINIO_ROOT_USER=whumpfadmin
MINIO_ROOT_PASSWORD=change-me                  # openssl rand -base64 18

# --- FastAPI / JWT ----------------------------------------------------------
WHUMPF_ENV=dev                                 # set to "prod" in production
JWT_SECRET=run-openssl-rand-hex-32-here        # openssl rand -hex 32

# --- CORS / frontend wiring -------------------------------------------------
# Local dev — Vite on :5173, all services on localhost.
# Prod — replace with your actual domain(s). CORS_ALLOW_ORIGINS accepts a
# comma-separated list if you need multiple origins.
CORS_ALLOW_ORIGINS=http://localhost:5173
VITE_API_URL=http://localhost:8000
VITE_MARTIN_URL=http://localhost:3000
VITE_TITILER_URL=http://localhost:8001
