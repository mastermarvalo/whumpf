# -----------------------------------------------------------------------------
# Whumpf — environment template
#
# Copy to .env and fill in real values.  Never commit .env.
#
# Prod setup
# ----------
# Set ALL values before running `make up` for the first time. The Postgres
# and MinIO volumes initialize from these on first start — changing them
# afterwards requires either nuking volumes or manual intervention inside
# the containers (ALTER ROLE in psql, mc admin user in MinIO).
#
# Generate secrets:
#   JWT_SECRET          →  openssl rand -hex 32
#   POSTGRES_PASSWORD   →  openssl rand -base64 24
#   MINIO_ROOT_PASSWORD →  openssl rand -base64 18   (must be ≥ 8 chars)
#   STRAVA_TOKEN_KEY    →  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# -----------------------------------------------------------------------------

# --- PostGIS ----------------------------------------------------------------
# POSTGRES_USER / POSTGRES_DB — pick a name (e.g. whumpf). Set once, never
# change without nuking the volume or running ALTER ROLE / ALTER DATABASE.
POSTGRES_DB=whumpf
POSTGRES_USER=whumpf
POSTGRES_PASSWORD=change-me                    # openssl rand -base64 24

# --- MinIO ------------------------------------------------------------------
# MINIO_ROOT_USER: min 3 chars. MINIO_ROOT_PASSWORD: min 8 chars.
# Same first-run rule applies — set before `make up`, or nuke the volume to
# change.
MINIO_ROOT_USER=whumpfadmin
MINIO_ROOT_PASSWORD=change-me                  # openssl rand -base64 18

# --- FastAPI / JWT ----------------------------------------------------------
WHUMPF_ENV=dev                                 # set to "prod" in production
JWT_SECRET=run-openssl-rand-hex-32-here        # openssl rand -hex 32

# --- CORS / frontend wiring -------------------------------------------------
# Local dev — Vite on :5173, all services on localhost.
# Prod — replace with your actual domain(s). CORS_ALLOW_ORIGINS accepts a
# comma-separated list if you need multiple origins.
CORS_ALLOW_ORIGINS=http://localhost:5173
VITE_API_URL=http://localhost:8000
VITE_MARTIN_URL=http://localhost:3000
VITE_TITILER_URL=http://localhost:8001
# "prod" (nginx + minified bundle) or "dev" (Vite dev server with HMR).
# Defaults to prod. Switch to dev locally if you want hot-reload.
FRONTEND_TARGET=prod

# --- Observability (frontend, baked at build time) ----------------------------
# Sentry: sign up at https://sentry.io, grab the project DSN, paste here. When
# empty, errors fall through to console.error.
VITE_SENTRY_DSN=
# Plausible: set the domain you configured at https://plausible.io (or your
# self-hosted instance). VITE_PLAUSIBLE_SRC overrides the script URL when
# self-hosting; default is https://plausible.io/js/script.js.
VITE_PLAUSIBLE_DOMAIN=
VITE_PLAUSIBLE_SRC=

# --- Strava OAuth (optional) ------------------------------------------------
# Required only if you want Strava activity overlays.
# Create an app at https://www.strava.com/settings/api
# Set "Authorization Callback Domain" to your host (e.g. localhost for dev).
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:8000/auth/strava/callback
STRAVA_SUCCESS_URL=http://localhost:5173
# Encrypts Strava OAuth tokens at rest. Leave empty for dev (legacy plaintext);
# required for prod. Rotate by re-running the openssl/Fernet generator above.
STRAVA_TOKEN_KEY=

# --- Account lifecycle / email --------------------------------------------------
# Base URL where users land — used to build verify/reset links inside emails.
APP_BASE_URL=http://localhost:5173
# Mail provider: "console" (logs URLs, useful for dev/staging without SMTP) or
# "resend" (https://resend.com). For prod, sign up for Resend (free tier),
# add a sender domain, set RESEND_API_KEY and switch MAIL_PROVIDER.
MAIL_PROVIDER=console
MAIL_FROM=whumpf <no-reply@whumpf.local>
RESEND_API_KEY=
