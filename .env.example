# -----------------------------------------------------------------------------
# Whumpf — environment template
#
# Copy this to .env and fill in real values.  Never commit .env.
# Generate strong secrets with:
#   openssl rand -hex 32
# -----------------------------------------------------------------------------

# --- PostGIS ----------------------------------------------------------------
POSTGRES_DB=whumpf
POSTGRES_USER=whumpf
POSTGRES_PASSWORD=change-me-to-something-strong

# --- MinIO ------------------------------------------------------------------
# Root credentials. Must be at least 3 chars (user) / 8 chars (password).
MINIO_ROOT_USER=whumpfadmin
MINIO_ROOT_PASSWORD=change-me-to-something-strong

# --- FastAPI / JWT ----------------------------------------------------------
WHUMPF_ENV=dev
JWT_SECRET=run-openssl-rand-hex-32-and-paste-here

# --- CORS / frontend wiring -------------------------------------------------
# For local dev with Vite:
CORS_ALLOW_ORIGINS=http://localhost:5173
VITE_API_URL=http://localhost:8000
VITE_MARTIN_URL=http://localhost:3000
VITE_TITILER_URL=http://localhost:8001
